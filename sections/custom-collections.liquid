<section class="custom-collections-section">
  <div class="custom-collections-wrapper">

    {% if section.settings.heading != blank %}
      <div class="custom-collections-header">
        <h2>{{ section.settings.heading }}</h2>
      </div>
    {% endif %}

    <div class="custom-collections-grid">
      {% for block in section.blocks %}
        {% assign selected_collection = block.settings.collection %}

        <a
          class="custom-collection-card"
          href="{% if selected_collection != blank %}{{ selected_collection.url }}{% else %}#{% endif %}"
          {{ block.shopify_attributes }}
        >
          <div class="custom-collection-image-wrap">
            {% if block.settings.custom_image != blank %}
              <img
                src="{{ block.settings.custom_image | image_url: width: 900 }}"
                alt="{{ block.settings.title | escape }}"
                class="custom-collection-image"
                loading="lazy"
              >
            {% elsif selected_collection.featured_image != blank %}
              <img
                src="{{ selected_collection.featured_image | image_url: width: 900 }}"
                alt="{{ selected_collection.title | escape }}"
                class="custom-collection-image"
                loading="lazy"
              >
            {% else %}
              <div class="custom-collection-placeholder">
                {{ 'collection-1' | placeholder_svg_tag }}
              </div>
            {% endif %}
          </div>

          <div class="custom-collection-content">
            <h3>
              {% if block.settings.title != blank %}
                {{ block.settings.title }}
              {% elsif selected_collection != blank %}
                {{ selected_collection.title }}
              {% else %}
                Yogurt Collection
              {% endif %}
            </h3>

            {% if block.settings.description != blank %}
              <p>{{ block.settings.description }}</p>
            {% endif %}
          </div>
        </a>
      {% endfor %}
    </div>

  </div>
</section>

<style>
@property --custom-gradient-angle {
  syntax: "<angle>";
  initial-value: 0turn;
  inherits: false;
}

/* ================================
SECTION
================================ */

.custom-collections-section{
  width:100%;
  padding:45px 5%;
  background:#fff;
}

.custom-collections-wrapper{
  max-width:860px;
  margin:auto;
}

/* ================================
HEADER
================================ */

.custom-collections-header{
  text-align:center;
  margin-bottom:26px;
}

.custom-collections-header h2{
  margin:0;
  color:#111;
  font-size:clamp(26px,4vw,40px);
  line-height:1;
  font-weight:900;
  letter-spacing:-0.04em;
}

/* ================================
GRID
================================ */

.custom-collections-grid{
  display:grid;
  grid-template-columns:repeat(3,1fr);
  gap:14px;
}

/* ================================
CARD
================================ */

.custom-collection-card{
  position:relative;
  display:block;

  overflow:hidden;

  text-decoration:none;

  border:2px solid transparent;
  border-radius:16px;

  background-image:
    linear-gradient(#fff,#fff),
    conic-gradient(
      from var(--custom-gradient-angle),
      #6f531e,
      #F0BD59,
      #fff0b3,
      #F0BD59,
      #6f531e,
      #F0BD59,
      #fff0b3,
      #6f531e
    );

  background-clip:
    padding-box,
    border-box;

  animation:
    customCollectionBorder 5s linear infinite;

  transition:.3s;

  box-shadow:
    0 8px 20px rgba(0,0,0,.06);
}

.custom-collection-card:hover{
  transform:translateY(-4px);

  box-shadow:
    0 14px 26px rgba(240,189,89,.18);
}

@keyframes customCollectionBorder{
  to{
    --custom-gradient-angle:1turn;
  }
}

/* ================================
IMAGE
================================ */

.custom-collection-image-wrap{
  width:100%;
  aspect-ratio:1/1;

  overflow:hidden;

  background:#fff;
}

.custom-collection-image{
  width:100%;
  height:100%;

  object-fit:cover;

  transition:.6s;
}

.custom-collection-card:hover .custom-collection-image{
  transform:scale(1.04);
}

/* ================================
PLACEHOLDER
================================ */

.custom-collection-placeholder{
  width:100%;
  height:100%;

  display:flex;

  justify-content:center;

  align-items:center;
}

.custom-collection-placeholder svg{
  width:50%;
  opacity:.25;
}

/* ================================
CONTENT
================================ */

.custom-collection-content{
  padding:12px;
  text-align:center;
}

.custom-collection-content h3{
  margin:0 0 5px;

  color:#111;

  font-size:16px;

  font-weight:900;

  line-height:1.2;
}

.custom-collection-content p{
  margin:0;

  color:#666;

  font-size:11px;

  line-height:1.45;
}

/* ================================
TABLET
================================ */

@media(max-width:900px){

.custom-collections-grid{
gap:10px;
}

.custom-collection-content h3{
font-size:14px;
}

.custom-collection-content p{
font-size:10px;
}

}

/* ================================
MOBILE
3 CARDS ROW
================================ */

@media(max-width:640px){

.custom-collections-section{
padding:28px 10px;
}

.custom-collections-header{
margin-bottom:16px;
}

.custom-collections-header h2{
font-size:22px;
}

.custom-collections-grid{

grid-template-columns:
repeat(3,minmax(0,1fr));

gap:8px;

}

.custom-collection-card{

border-radius:12px;

}

.custom-collection-card:hover{
transform:none;
}

.custom-collection-image-wrap{

aspect-ratio:
0.9/1;

}

.custom-collection-content{

padding:
8px 6px 10px;

}

.custom-collection-content h3{

font-size:
11px;

line-height:
1.15;

margin-bottom:
3px;

}

.custom-collection-content p{

font-size:
8px;

line-height:
1.3;

}

}

/* ================================
VERY SMALL MOBILE
================================ */

@media(max-width:420px){

.custom-collections-grid{

gap:6px;

}

.custom-collection-card{

border-radius:10px;

}

.custom-collection-content{

padding:6px;

}

.custom-collection-content h3{

font-size:10px;

}

.custom-collection-content p{

display:none;

}

}
</style>

{% schema %}
{
  "name": "Custom Collections",
  "settings": [
    {
      "type": "text",
      "id": "heading",
      "label": "Section heading",
      "default": "Shop Our Yogurt Collections"
    }
  ],
  "blocks": [
    {
      "type": "collection_card",
      "name": "Collection Card",
      "limit": 3,
      "settings": [
        {
          "type": "collection",
          "id": "collection",
          "label": "Choose collection"
        },
        {
          "type": "image_picker",
          "id": "custom_image",
          "label": "Custom image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Custom title",
          "default": "Yogurt Collection"
        },
        {
          "type": "textarea",
          "id": "description",
          "label": "Card description",
          "default": "Smooth, creamy yogurt crafted with premium ingredients."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Custom Collections",
      "blocks": [
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        },
        {
          "type": "collection_card"
        }
      ]
    }
  ]
}
{% endschema %}