<section class="viora-different">
  <div class="viora-different-wrap">

    <div class="viora-different-text">
      <p class="viora-kicker">{{ section.settings.kicker }}</p>
      <h2>{{ section.settings.heading }}</h2>
      <p class="viora-desc">{{ section.settings.description }}</p>
    </div>

    <div class="viora-benefits">
      {% for block in section.blocks %}
        <div class="viora-benefit" {{ block.shopify_attributes }}>
          {% if block.settings.icon != blank %}
            <img src="{{ block.settings.icon | image_url: width: 120 }}" alt="{{ block.settings.title | escape }}">
          {% endif %}
          <h3>{{ block.settings.title }}</h3>
          <p>{{ block.settings.text }}</p>
        </div>
      {% endfor %}
    </div>

  </div>
</section>

<style>
.viora-different {
  background: #090909;
  color: #fff;
  padding: 34px 5%;
  border-top: 1px solid rgba(214, 166, 82, 0.35);
  border-bottom: 1px solid rgba(214, 166, 82, 0.35);
}

.viora-different-wrap {
  max-width: 1350px;
  margin: 0 auto;
  display: grid;
  grid-template-columns: 1.4fr 3fr;
  gap: 34px;
  align-items: center;
}

.viora-kicker {
  color: #d6a652;
  font-size: 12px;
  letter-spacing: 2px;
  font-weight: 700;
  margin: 0 0 8px;
}

.viora-different-text h2 {
  color: #fff;
  font-size: 30px;
  line-height: 1.05;
  margin: 0 0 10px;
  font-weight: 700;
}

.viora-desc {
  color: #f0d7b0;
  font-size: 16px;
  line-height: 1.4;
  margin: 0;
}

.viora-benefits {
  display: grid;
  grid-template-columns: repeat(4, 1fr);
  border-left: 1px solid rgba(214, 166, 82, 0.35);
}

.viora-benefit {
  text-align: center;
  padding: 8px 24px;
  border-right: 1px solid rgba(214, 166, 82, 0.35);
}

.viora-benefit img {
  width: 46px;
  height: 46px;
  object-fit: contain;
  margin-bottom: 8px;
}

.viora-benefit h3 {
  color: #d6a652;
  font-size: 15px;
  line-height: 1.15;
  margin: 0 0 7px;
  font-weight: 800;
}

.viora-benefit p {
  color: #f7f0e6;
  font-size: 12px;
  line-height: 1.45;
  margin: 0;
}

@media screen and (max-width: 900px) {
  .viora-different-wrap {
    grid-template-columns: 1fr;
    gap: 24px;
  }

  .viora-benefits {
    grid-template-columns: repeat(2, 1fr);
    border-left: none;
  }

  .viora-benefit {
    border: 1px solid rgba(214, 166, 82, 0.25);
    padding: 22px 16px;
  }
}

@media screen and (max-width: 520px) {
  .viora-different {
    padding: 32px 16px;
  }

  .viora-different-text h2 {
    font-size: 25px;
  }

  .viora-benefits {
    grid-template-columns: 1fr;
  }
}
</style>

{% schema %}
{
  "name": "VIORA Different",
  "settings": [
    {
      "type": "text",
      "id": "kicker",
      "label": "Small title",
      "default": "WHY VIORA IS DIFFERENT"
    },
    {
      "type": "textarea",
      "id": "heading",
      "label": "Heading",
      "default": "Most high-protein yogurts are too sour, too thick, or full of artificial junk."
    },
    {
      "type": "textarea",
      "id": "description",
      "label": "Description",
      "default": "VIORA is smooth, creamy, lightly sweet, and made with real ingredients."
    }
  ],
  "blocks": [
    {
      "type": "benefit",
      "name": "Icon Benefit",
      "limit": 4,
      "settings": [
        {
          "type": "image_picker",
          "id": "icon",
          "label": "Icon image"
        },
        {
          "type": "text",
          "id": "title",
          "label": "Title",
          "default": "Real Ingredients"
        },
        {
          "type": "textarea",
          "id": "text",
          "label": "Text",
          "default": "Made with real milk and simple, clean ingredients."
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "VIORA Different",
      "blocks": [
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" },
        { "type": "benefit" }
      ]
    }
  ]
}
{% endschema %}