<section class="product-marquee section-{{ section.id }}">
  <div class="product-marquee__track">
    {% for i in (1..2) %}
      {% for block in section.blocks %}
        {% assign product = block.settings.product %}

        {% if block.type == 'text_card' %}
          <div class="product-marquee__item product-marquee__text-card">
            <h2>{{ block.settings.heading }}</h2>

            {% if block.settings.subtext != blank %}
              <p>{{ block.settings.subtext }}</p>
            {% endif %}

            {% if block.settings.link_label != blank %}
              <a href="{{ block.settings.link_url }}">
                {{ block.settings.link_label }}
              </a>
            {% endif %}
          </div>
        {% endif %}

        {% if block.type == 'product_card' and product != blank %}
          <a href="{{ product.url }}" class="product-marquee__item product-marquee__product">
            {% if product.featured_image != blank %}
              <img
                src="{{ product.featured_image | image_url: width: 900 }}"
                alt="{{ product.featured_image.alt | escape }}"
                loading="lazy"
              >
            {% endif %}

            {% if section.settings.show_product_title %}
              <h3>{{ product.title }}</h3>
            {% endif %}

            {% if section.settings.show_price %}
              <p>{{ product.price | money }}</p>
            {% endif %}
          </a>
        {% endif %}
      {% endfor %}
    {% endfor %}
  </div>
</section>

<style>
.section-{{ section.id }} {
  width: 100%;
  overflow: hidden;
  background: {{ section.settings.background }};
  border-top: {{ section.settings.border_size }}px solid {{ section.settings.border_color }};
  border-bottom: {{ section.settings.border_size }}px solid {{ section.settings.border_color }};
}

.section-{{ section.id }} .product-marquee__track {
  display: flex;
  width: max-content;
  animation: productMarquee-{{ section.id }} {{ section.settings.speed }}s linear infinite;
}

.section-{{ section.id }}:hover .product-marquee__track {
  {% if section.settings.pause_on_hover %}
    animation-play-state: paused;
  {% endif %}
}

.section-{{ section.id }} .product-marquee__item {
  width: {{ section.settings.card_width }}px;
  height: {{ section.settings.section_height }}px;
  flex: 0 0 auto;
  border-right: 1px solid {{ section.settings.divider_color }};
  display: flex;
  align-items: center;
  justify-content: center;
  text-decoration: none;
  color: inherit;
  background: #fff;
  overflow: hidden;
}

.section-{{ section.id }} .product-marquee__product {
  flex-direction: column;
  padding: 24px;
}

.section-{{ section.id }} .product-marquee__product img {
  width: 100%;
  height: 82%;
  object-fit: contain;
  transition: transform 0.35s ease;
}

.section-{{ section.id }} .product-marquee__product:hover img {
  transform: scale(1.04);
}

.section-{{ section.id }} .product-marquee__product h3 {
  margin: 12px 0 4px;
  font-size: 15px;
  font-weight: 700;
  text-align: center;
}

.section-{{ section.id }} .product-marquee__product p {
  margin: 0;
  font-size: 14px;
}

.section-{{ section.id }} .product-marquee__text-card {
  background: {{ section.settings.text_card_background }};
  color: {{ section.settings.text_card_color }};
  flex-direction: column;
  text-align: center;
  padding: 40px;
}

.section-{{ section.id }} .product-marquee__text-card h2 {
  margin: 0;
  font-size: clamp(34px, 4vw, 62px);
  font-weight: 400;
  line-height: 1.1;
}

.section-{{ section.id }} .product-marquee__text-card p {
  margin-top: 14px;
  font-size: 16px;
}

.section-{{ section.id }} .product-marquee__text-card a {
  margin-top: 26px;
  color: {{ section.settings.text_card_color }};
  font-size: 13px;
  font-weight: 800;
  letter-spacing: 1px;
  text-transform: uppercase;
  text-decoration: none;
  border-bottom: 1px solid currentColor;
  padding-bottom: 6px;
}

@keyframes productMarquee-{{ section.id }} {
  from {
    transform: translateX(0);
  }
  to {
    transform: translateX(-50%);
  }
}

@media (max-width: 768px) {
  .section-{{ section.id }} .product-marquee__item {
    width: {{ section.settings.mobile_card_width }}px;
    height: {{ section.settings.mobile_height }}px;
  }

  .section-{{ section.id }} .product-marquee__product {
    padding: 18px;
  }

  .section-{{ section.id }} .product-marquee__text-card {
    padding: 28px;
  }
}
</style>

{% schema %}
{
  "name": "Product Auto Scroll",
  "settings": [
    {
      "type": "range",
      "id": "section_height",
      "label": "Desktop height",
      "min": 250,
      "max": 700,
      "step": 10,
      "default": 450
    },
    {
      "type": "range",
      "id": "mobile_height",
      "label": "Mobile height",
      "min": 220,
      "max": 600,
      "step": 10,
      "default": 340
    },
    {
      "type": "range",
      "id": "card_width",
      "label": "Desktop card width",
      "min": 220,
      "max": 700,
      "step": 10,
      "default": 460
    },
    {
      "type": "range",
      "id": "mobile_card_width",
      "label": "Mobile card width",
      "min": 180,
      "max": 420,
      "step": 10,
      "default": 280
    },
    {
      "type": "range",
      "id": "speed",
      "label": "Scroll speed",
      "min": 10,
      "max": 80,
      "step": 2,
      "default": 32
    },
    {
      "type": "checkbox",
      "id": "pause_on_hover",
      "label": "Pause on hover",
      "default": true
    },
    {
      "type": "checkbox",
      "id": "show_product_title",
      "label": "Show product title",
      "default": false
    },
    {
      "type": "checkbox",
      "id": "show_price",
      "label": "Show product price",
      "default": false
    },
    {
      "type": "color",
      "id": "background",
      "label": "Section background",
      "default": "#ffffff"
    },
    {
      "type": "color",
      "id": "border_color",
      "label": "Top and bottom border color",
      "default": "#ed1c24"
    },
    {
      "type": "range",
      "id": "border_size",
      "label": "Top and bottom border size",
      "min": 0,
      "max": 40,
      "step": 1,
      "default": 2
    },
    {
      "type": "color",
      "id": "divider_color",
      "label": "Card divider color",
      "default": "#cccccc"
    },
    {
      "type": "color",
      "id": "text_card_background",
      "label": "Text card background",
      "default": "#202020"
    },
    {
      "type": "color",
      "id": "text_card_color",
      "label": "Text card text color",
      "default": "#ffffff"
    }
  ],
  "blocks": [
    {
      "type": "text_card",
      "name": "Text card",
      "limit": 1,
      "settings": [
        {
          "type": "text",
          "id": "heading",
          "label": "Heading",
          "default": "Join the family"
        },
        {
          "type": "text",
          "id": "subtext",
          "label": "Sub text",
          "default": "Follow us"
        },
        {
          "type": "text",
          "id": "link_label",
          "label": "Link label",
          "default": "Follow us"
        },
        {
          "type": "url",
          "id": "link_url",
          "label": "Link URL"
        }
      ]
    },
    {
      "type": "product_card",
      "name": "Product",
      "settings": [
        {
          "type": "product",
          "id": "product",
          "label": "Select product"
        }
      ]
    }
  ],
  "presets": [
    {
      "name": "Product Auto Scroll",
      "blocks": [
        {
          "type": "text_card"
        },
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        },
        {
          "type": "product_card"
        }
      ]
    }
  ]
}
{% endschema %}