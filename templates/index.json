%;\n  z-index: 50;\n\n  display: flex;\n  align-items: center;\n  gap: clamp(10px, 1.2vw, 22px);\n\n  line-height: normal;\n}\n\n.viora-hero-btn {\n  display: inline-flex;\n  align-items: center;\n  justify-content: center;\n\n  min-height: clamp(34px, 2.9vw, 50px);\n  padding: 0 clamp(16px, 1.9vw, 34px);\n\n  border-radius: 7px;\n  text-decoration: none !important;\n\n  font-size: clamp(8px, 0.86vw, 15px);\n  font-weight: 900;\n  letter-spacing: 0.25px;\n  text-transform: uppercase;\n  white-space: nowrap;\n\n  cursor: pointer;\n  transition: all 0.25s ease;\n}\n\n.viora-btn-gold {\n  color: #111 !important;\n  background: linear-gradient(135deg, #f8df9f 0%, #d2a451 48%, #f2cf7e 100%);\n  border: 1px solid rgba(255, 226, 165, 0.95);\n  box-shadow:\n    0 8px 22px rgba(0, 0, 0, 0.35),\n    inset 0 1px 0 rgba(255, 255, 255, 0.38);\n}\n\n.viora-btn-dark {\n  color: #fff7e6 !important;\n  background: rgba(0, 0, 0, 0.84);\n  border: 1.5px solid #d6ad63;\n  box-shadow:\n    0 8px 22px rgba(0, 0, 0, 0.35),\n    inset 0 1px 0 rgba(255, 255, 255, 0.08);\n}\n\n.viora-hero-btn:hover {\n  transform: translateY(-2px);\n  opacity: 0.96;\n}\n\n\/* Hide mobile CTA on desktop *\/\n.viora-mobile-cta {\n  display: none;\n}\n\n\/* ========================================\n   TABLET\n======================================== *\/\n\n@media screen and (max-width: 989px) and (min-width: 750px) {\n  .viora-hero-buttons {\n    left: 4.2%;\n    top: 68.7%;\n    gap: 8px;\n  }\n\n  .viora-hero-btn {\n    min-height: 28px;\n    padding: 0 13px;\n    font-size: 7.4px;\n    border-radius: 5px;\n  }\n}\n\n\/* ========================================\n   MOBILE\n======================================== *\/\n\n@media screen and (max-width: 749px) {\n  .viora-hero-section {\n    background: #000;\n  }\n\n  .viora-hero-wrapper {\n    width: 100%;\n    overflow: hidden;\n  }\n\n  .viora-hero-img {\n    width: 100%;\n    height: auto;\n    display: block;\n  }\n\n  \/* Hide desktop overlay buttons on mobile *\/\n  .viora-desktop-buttons {\n    display: none;\n  }\n\n  \/* Show large mobile CTA buttons below image *\/\n  .viora-mobile-cta {\n    display: flex;\n    flex-direction: column;\n    gap: 10px;\n\n    width: 100%;\n    padding: 16px 18px 20px;\n\n    background:\n      linear-gradient(\n        180deg,\n        #000 0%,\n        #070604 45%,\n        #0d0904 100%\n      );\n\n    border-top: 1px solid rgba(214, 173, 99, 0.35);\n  }\n\n  .viora-mobile-btn {\n    display: flex;\n    align-items: center;\n    justify-content: center;\n\n    width: 100%;\n    min-height: 48px;\n\n    border-radius: 10px;\n    text-decoration: none !important;\n\n    font-size: 13px;\n    font-weight: 900;\n    letter-spacing: 0.3px;\n    text-transform: uppercase;\n\n    cursor: pointer;\n    transition: all 0.25s ease;\n  }\n\n  .viora-mobile-btn-gold {\n    color: #111 !important;\n    background: linear-gradient(135deg, #f8df9f 0%, #d2a451 48%, #f2cf7e 100%);\n    border: 1px solid rgba(255, 226, 165, 0.95);\n    box-shadow:\n      0 8px 22px rgba(0, 0, 0, 0.35),\n      inset 0 1px 0 rgba(255, 255, 255, 0.35);\n  }\n\n  .viora-mobile-btn-dark {\n    color: #fff7e6 !important;\n    background: rgba(0, 0, 0, 0.84);\n    border: 1.5px solid #d6ad63;\n    box-shadow:\n      0 8px 22px rgba(0, 0, 0, 0.35),\n      inset 0 1px 0 rgba(255, 255, 255, 0.08);\n  }\n\n  .viora-mobile-btn:hover {\n    opacity: 0.96;\n  }\n}\n\n\/* Very small phones *\/\n@media screen and (max-width: 390px) {\n  .viora-mobile-cta {\n    padding: 14px 14px 18px;\n    gap: 9px;\n  }\n\n  .viora-mobile-btn {\n    min-height: 45px;\n    font-size: 12px;\n    border-radius: 9px;\n  }\n}\n<\/style>","color_scheme":"","padding_top":0,"padding_bottom":0}},"viora_icon_benefits_qNDGN7":{"type":"viora-icon-benefits","blocks":{"benefit_arAXgB":{"type":"benefit","settings":{"icon_image":"shopify:\/\/shop_images\/high_protein-removebg-preview.png","title":"High Protein","text":"Up to 20g protein per jar to help keep 