iora-bundle-inner {\n  max-width: 1450px;\n  margin: 0 auto;\n  padding: 48px 4.2% 18px;\n\n  display: grid;\n  grid-template-columns: 1.18fr 1.08fr 0.55fr;\n  align-items: center;\n  gap: 24px;\n}\n\n\/* Jar lineup *\/\n.viora-bundle-left {\n  position: relative;\n}\n\n.viora-bundle-lineup-card {\n  position: relative;\n  padding: 14px 0 8px;\n}\n\n.viora-bundle-tray {\n  position: absolute;\n  left: 8%;\n  right: 8%;\n  bottom: 34px;\n  height: 66px;\n  border-radius: 50%;\n  background: radial-gradient(\n    circle,\n    rgba(92,61,18,0.16) 0%,\n    rgba(92,61,18,0.06) 48%,\n    transparent 76%\n  );\n  filter: blur(8px);\n}\n\n.viora-bundle-lineup {\n  position: relative;\n  min-height: 212px;\n  display: flex;\n  align-items: flex-end;\n  justify-content: center;\n  gap: 0;\n  filter: drop-shadow(0 16px 24px rgba(75,48,13,0.14));\n}\n\n.bundle-jar {\n  position: relative;\n  width: 82px;\n  margin-right: -8px;\n  display: flex;\n  align-items: flex-end;\n  justify-content: center;\n}\n\n.bundle-jar:last-child {\n  margin-right: 0;\n}\n\n.bundle-jar img {\n  display: block;\n  height: 118px !important;\n  width: auto !important;\n  max-width: none !important;\n  object-fit: contain !important;\n}\n\n.jar-matcha {\n  z-index: 1;\n  transform: translateY(9px) scale(0.94);\n}\n\n.jar-pandan {\n  z-index: 2;\n  transform: translateY(5px) scale(0.98);\n}\n\n.jar-plain {\n  z-index: 5;\n  transform: translateY(1px) scale(1.02);\n}\n\n.jar-ube {\n  z-index: 4;\n  transform: translateY(0) scale(1.04);\n}\n\n.jar-coffee {\n  z-index: 3;\n  transform: translateY(5px) scale(0.98);\n}\n\n.jar-caramel {\n  z-index: 2;\n  transform: translateY(9px) scale(0.94);\n}\n\n.viora-bundle-caption {\n  margin: 8px 0 0;\n  text-align: center;\n  color: #946824;\n  font-size: 12px;\n  font-weight: 900;\n  letter-spacing: 0.8px;\n  text-transform: uppercase;\n}\n\n\/* Text *\/\n.viora-bundle-copy {\n  text-align: center;\n}\n\n.viora-bundle-eyebrow {\n  margin: 0 0 10px;\n  color: #9b691